{
  "name": "ringtone-maker",
  "version": "1.0.0",
  "description": "Browser-based iPhone ringtone maker",
  "type": "commonjs",
  "scripts": {
    "build:client": "esbuild src/client/app.ts --bundle --format=esm --outfile=public/js/app.js --platform=browser",
    "dev": "npm run build:client && tsx watch src/server.ts",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"public/**/*.html\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "wavesurfer.js": "^7.7.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
